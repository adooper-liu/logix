## 自动化验证

### PowerShell 检查脚本

```powershell
function Test-SKILLPrinciple {
    param([string]$FilePath)
    
    $content = Get-Content $FilePath -Raw
    $emojiPattern = '[🎯📁⭐🚀📋🤖✅❌📊💡🔗🎉💪📄📌📈🔄🛠️🎊]'
    
    if ($content -match $emojiPattern) {
        Write-Host "FAIL: 发现 emoji 表情" -ForegroundColor Red
        return $false
    }
    
    if ($content -match '←|→|➤') {
        Write-Host "WARN: 发现装饰性箭头" -ForegroundColor Yellow
        return $false
    }
    
    Write-Host "OK: 符合 SKILL 原则" -ForegroundColor Green
    return $true
}
```

