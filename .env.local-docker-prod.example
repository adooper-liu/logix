# ============================================
# 本地 Docker 生产栈演示用 .env 模板
# 复制为仓库根目录 .env：Copy-Item .env.local-docker-prod.example .env
# 与 docker-compose.timescaledb.prod.yml + docker-compose.prod.local-demo.yml 配套
# ============================================

NODE_ENV=production
PORT=3001
API_PREFIX=/api/v1

# 数据库（首次启动会执行 init SQL；若已有数据卷则不会重新初始化）
DB_USERNAME=logix_user
DB_PASSWORD=local_demo_change_me
DB_DATABASE=logix_db
DB_PORT=5432

# 笔记本可酌情调低（可选）
PG_MEMORY=2GB
PG_CPUS=2
PG_MAX_CONNECTIONS=50
PG_SHARED_BUFFERS=512MB
PG_EFFECTIVE_CACHE=1536MB
PG_MAINTENANCE_WORK_MEM=128MB
PG_MAX_WORKERS=4
PG_PARALLEL_WORKERS=2
PG_WORK_MEM=4MB

REDIS_PORT=6379
REDIS_PASSWORD=local_redis_change_me

ES_PORT=9200
ES_SECURITY_ENABLED=false
ES_HEAP_SIZE=512m

# 浏览器访问 http://localhost 时的 CORS
CORS_ORIGIN=http://localhost
SOCKET_CORS_ORIGIN=http://localhost

LOG_LEVEL=info

# 飞驼（可留空，仅测 Excel 等）
FEITUO_API_BASE_URL=https://openapi.freightower.com
FEITUO_CLIENT_ID=
FEITUO_CLIENT_SECRET=
FEITUO_ACCESS_TOKEN=

# Grafana（子路径 /grafana/）
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_local_change_me
GRAFANA_ROOT_URL=http://localhost/grafana/
