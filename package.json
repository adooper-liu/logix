{
  "name": "logix-monorepo",
  "version": "1.0.0",
  "description": "LogiX 项目 Lint 配置",
  "scripts": {
    "lint": "npm run lint:backend && npm run lint:frontend && npm run lint:md",
    "check": "node scripts/dev-paradigm-check.js",
    "check:all": "node scripts/dev-paradigm-check.js --all-phases",
    "check:arch": "node scripts/dev-paradigm-check.js --phase architecture",
    "check:problem": "node scripts/dev-paradigm-check.js --phase problem",
    "check:strategy": "node scripts/dev-paradigm-check.js --phase strategy",
    "check:review": "node scripts/dev-paradigm-check.js --phase review",
    "check:dev": "node scripts/dev-paradigm-check.js --phase development",
    "check:test": "node scripts/dev-paradigm-check.js --phase testing",
    "check:retro": "node scripts/dev-paradigm-check.js --phase retrospective",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:md": "markdownlint-cli2 \"frontend/public/docs/**/*.md\" \"./*.md\"",
    "lint:fix": "npm run lint:fix:backend && npm run lint:fix:frontend && npm run lint:fix:md",
    "lint:fix:backend": "cd backend && npm run lint -- --fix",
    "lint:fix:frontend": "cd frontend && npm run lint -- --fix",
    "lint:fix:md": "markdownlint-cli2 \"frontend/public/docs/**/*.md\" \"./*.md\" --fix",
    "lint:naming": "npm run lint:naming:backend && npm run lint:naming:frontend",
    "lint:naming:backend": "cd backend && npm run lint",
    "lint:naming:frontend": "cd frontend && npm run lint",
    "format": "npm run format:backend && npm run format:frontend && npm run format:md",
    "format:backend": "cd backend && npm run format",
    "format:frontend": "cd frontend && npm run format",
    "format:md": "markdownlint-cli2 \"frontend/public/docs/**/*.md\" \"./*.md\" --fix",
    "type-check": "npm run type-check:backend && npm run type-check:frontend",
    "type-check:backend": "cd backend && npm run type-check",
    "type-check:frontend": "cd frontend && npm run type-check",
    "type-check:frontend:ci": "cd frontend && npx vue-tsc --noEmit -p tsconfig.ci.json",
    "validate": "npm run type-check && npm run lint && npm run lint:naming",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:backend:scheduling": "cd backend && npm run test:scheduling",
    "test:frontend": "cd frontend && npm test",
    "quality": "npm run validate && npm run test",
    "quality:ci": "npm run test && npm run type-check:backend && npm run lint:backend",
    "verify:stats-filter": "cd backend && npm run verify:stats-filter",
    "diagnose:country-filter": "node scripts/diagnose-country-filter.js",
    "test:statistics-fix": "node scripts/test-statistics-fix.js"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "markdownlint-cli2": "^0.21.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "ollama": "^0.6.3",
    "pg": "^8.20.0",
    "shiki": "^4.0.0",
    "vue-i18n": "^9.14.4",
    "xlsx": "^0.18.5"
  }
}
