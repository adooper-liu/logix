# 应用配置
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# 微服务配置
LOGISTICS_PATH_SERVICE_URL=http://localhost:4000
LOGISTICS_PATH_SERVICE_TOKEN=

# 飞驼API配置（Token 留空时仅 Excel 导入可用，补入后即可运行）
# FEITUO_API_BASE_URL=https://openapi.freightower.com
FEITUO_CLIENT_ID=
FEITUO_CLIENT_SECRET=
FEITUO_ACCESS_TOKEN=

# 适配器配置
DEFAULT_ADAPTER_SOURCE=logistics_path
ADAPTER_HEALTH_CHECK_INTERVAL=60000
ADAPTER_ENABLE_AUTO_FAILOVER=true

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# Socket.IO 配置
SOCKET_CORS_ORIGIN=http://localhost:5173

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 健康检查配置
HEALTH_CHECK_INTERVAL=60000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=logix_db
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# 调度器启动延迟配置（秒）
# Scheduler Startup Delay Configuration
# ============================================

# 货柜状态调度器首次执行延迟（秒）
STATUS_SCHEDULER_DELAY=5

# 滞港费调度器首次执行延迟（秒）
# 建议比 STATUS_SCHEDULER_DELAY 至少大 10 秒，避免资源竞争
DEMURRAGE_WRITEBACK_SCHEDULER_DELAY=15

# ============================================
# 调度器批次大小配置
# Scheduler Batch Size Configuration
# ============================================

# 货柜状态更新批次大小（默认 200）
STATUS_BATCH_SIZE=200

# 滞港费计算批次大小（默认 200）
DEMURRAGE_BATCH_SIZE=200

# ============================================
# 健康检查超时配置（毫秒）
# Health Check Timeout Configuration
# ============================================

# 微服务健康检查超时时间（毫秒）
HEALTH_CHECK_TIMEOUT=5000

# Elasticsearch 配置
ES_NODE=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=

# ============================================
# AI 提供商配置
# AI Provider Configuration
# ============================================

# 选择 AI 提供商: siliconflow | ollama-local | ollama-cloud
AI_PROVIDER=siliconflow

# --- 硅基流动 AI 配置 ---
# 获取 API Key: https://siliconflow.cn
SILICON_FLOW_API_KEY=sk-xxxxxxxx
SILICON_FLOW_MODEL=deepseek-ai/DeepSeek-V2-Chat
SILICON_FLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICON_FLOW_TEMPERATURE=0.7
SILICON_FLOW_MAX_TOKENS=4096
SILICON_FLOW_TIMEOUT=60000

# --- Ollama Local 配置（本地部署）---
# 安装 Ollama: https://ollama.ai
# 拉取模型: ollama pull llama3.2
OLLAMA_MODEL=llama3.2
OLLAMA_LOCAL_BASE_URL=http://localhost:11434
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=4096
OLLAMA_TIMEOUT=60000

# --- Ollama Cloud 配置（云端服务）---
# 获取 API Key: https://docs.ollama.com/cloud
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=llama3.2
OLLAMA_CLOUD_BASE_URL=https://ollama.ai/api
OLLAMA_CLOUD_TEMPERATURE=0.7
OLLAMA_CLOUD_MAX_TOKENS=4096
OLLAMA_CLOUD_TIMEOUT=60000
