# ============================================
# LogiX 开发环境配置
# LogiX Development Environment Configuration
# ============================================

# 应用配置
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# TimescaleDB 数据库配置（以 start-logix-dev.ps1 为准：脚本用根目录 .env + docker-compose.timescaledb.prod.yml）
# DB_USERNAME / DB_PASSWORD / DB_DATABASE 由根目录 .env 提供（与容器创建时一致）；此处仅覆盖后端跑在主机时用的 DB_HOST
DB_HOST=localhost
DB_PORT=5432
DB_POOL_MIN=2
DB_POOL_MAX=10

# 数据库同步策略
# - true: 开发时实体修改自动同步（快速开发）
# - false: 使用SQL脚本管理（生产环境，更安全）
DB_SYNCHRONIZE=false

# Redis 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=LogiX@Redis!2024
REDIS_DB=0

# Elasticsearch 配置
ES_NODE=http://localhost:9200
ES_PORT=9200
ES_USERNAME=
ES_PASSWORD=
ES_SECURITY_ENABLED=false
ES_HEAP_SIZE=1g

# 飞驼 API 配置
FEITUO_API_ENDPOINT=https://api.feituo.com/v1
FEITUO_API_KEY=

# 日志配置
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# Socket.IO 配置
SOCKET_CORS_ORIGIN=http://localhost:5173

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# 健康检查配置
HEALTH_CHECK_INTERVAL=60000

# JWT 配置
JWT_SECRET=LogiX_JWT_Secret_Key_2024_ChaNge_This_In_Production
JWT_EXPIRE_TIME=24h

# 适配器配置
DEFAULT_ADAPTER_SOURCE=logistics_path
ADAPTER_HEALTH_CHECK_INTERVAL=60000
ADAPTER_ENABLE_AUTO_FAILOVER=true

# 微服务配置
LOGISTICS_PATH_SERVICE_URL=http://localhost:4000
LOGISTICS_PATH_SERVICE_TOKEN=

# 硅基流动 AI 配置（可选，未配置时 AI 对话功能不可用）
# 获取 API Key: https://cloud.siliconflow.cn/
SILICON_FLOW_API_KEY=sk-hxrctdhglbqxpdsakxszmqahecbvindojamxuldcxxhpzsxi
SILICON_FLOW_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct

# ============================================
# 调度器启动延迟配置（秒）
# Scheduler Startup Delay Configuration
# ============================================

# 货柜状态调度器首次执行延迟（秒）
STATUS_SCHEDULER_DELAY=5

# 滞港费调度器首次执行延迟（秒）
# 建议比 STATUS_SCHEDULER_DELAY 至少大 10 秒，避免资源竞争
DEMURRAGE_WRITEBACK_SCHEDULER_DELAY=15

# ============================================
# 调度器批次大小配置
# Scheduler Batch Size Configuration
# ============================================

# 货柜状态更新批次大小（默认 200）
STATUS_BATCH_SIZE=200

# 滞港费计算批次大小（默认 200）
DEMURRAGE_BATCH_SIZE=200

# ============================================
# 健康检查超时配置（毫秒）
# Health Check Timeout Configuration
# ============================================

# 微服务健康检查超时时间（毫秒）
HEALTH_CHECK_TIMEOUT=5000
