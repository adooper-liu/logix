# 应用配置
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# 微服务配置
LOGISTICS_PATH_SERVICE_URL=http://localhost:4000
LOGISTICS_PATH_SERVICE_TOKEN=

# 飞驼 API 配置
# FEITUO_API_BASE_URL=https://openapi.freightower.com
FEITUO_CLIENT_ID=
FEITUO_CLIENT_SECRET=
FEITUO_ACCESS_TOKEN=

# 适配器配置
DEFAULT_ADAPTER_SOURCE=logistics_path
ADAPTER_HEALTH_CHECK_INTERVAL=60000
ADAPTER_ENABLE_AUTO_FAILOVER=true

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# Socket.IO 配置
SOCKET_CORS_ORIGIN=http://localhost:5173

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 健康检查配置
HEALTH_CHECK_INTERVAL=60000
HEALTH_CHECK_TIMEOUT=5000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=logix_user
DB_PASSWORD=LogiX@2024!Secure
DB_DATABASE=logix_db
DB_SYNCHRONIZE=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=LogiX@Redis!2024
REDIS_DB=0

# Elasticsearch 配置
ES_NODE=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=

# 调度器启动延迟配置（秒）
STATUS_SCHEDULER_DELAY=5
DEMURRAGE_WRITEBACK_SCHEDULER_DELAY=15

# 调度器批次大小配置
STATUS_BATCH_SIZE=200
DEMURRAGE_BATCH_SIZE=200

# 状态更新定时任务配置（分钟）
STATUS_SCHEDULER_INTERVAL=60

# 滞港费写回定时任务配置（分钟）
DEMURRAGE_WRITEBACK_SCHEDULER_INTERVAL=1440
DEMURRAGE_WRITEBACK_SCHEDULER_DELAY=5

# 硅基流动 AI 配置（可选，未配置时 AI 功能不可用）
SILICON_FLOW_API_KEY=sk-hxrctdhglbqxpdsakxszmqahecbvindojamxuldcxxhpzsxi
SILICON_FLOW_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct