{
  "name": "logix-main-service",
  "version": "1.0.0",
  "description": "LogiX - 让复杂物流变得轻松愉快",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/server.ts",
    "dev:env": "cross-env NODE_ENV=development --env-file=.env.dev tsx watch src/server.ts",
    "backfill:feituo-events": "node -r ./scripts/load-env.cjs ./node_modules/tsx/dist/cli.mjs scripts/backfill-status-events-from-feituo-table2.ts",
    "simulate:schedule": "tsx scripts/simulate-schedule-one.ts",
    "check:country-tables": "tsx scripts/check-country-tables.ts",
    "trace:schedule": "tsx scripts/trace-schedule-params.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/typeorm": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.11.0",
    "axios": "^1.6.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jest": "^30.3.0",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "rxjs": "^7.8.2",
    "socket.io": "^4.6.1",
    "ts-jest": "^29.4.6",
    "typeorm": "^0.3.28",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
