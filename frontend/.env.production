# 生产环境配置

# API 基础 URL
VITE_API_BASE_URL=/api/v1

# 是否启用性能监控
VITE_ENABLE_PERFORMANCE_MONITOR=true

# 是否启用 API 缓存
VITE_ENABLE_API_CACHE=true

# 缓存默认时间（毫秒）
VITE_DEFAULT_CACHE_TTL=300000

# 是否启用虚拟滚动
VITE_ENABLE_VIRTUAL_SCROLL=true

# 是否启用懒加载
VITE_ENABLE_LAZY_LOADING=true

# 控制台日志级别
VITE_LOG_LEVEL=error
